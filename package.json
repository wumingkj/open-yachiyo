{
  "name": "open-yachiyo",
  "version": "0.1.1",
  "private": true,
  "main": "apps/desktop-live2d/main/electronMain.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node apps/gateway/server.js",
    "start": "node apps/gateway/server.js",
    "desktop:up": "node scripts/desktop-up.js",
    "desktop:smoke": "node scripts/desktop-live2d-smoke.js",
    "desktop:dev": "electron apps/desktop-live2d/main/electronMain.js",
    "desktop:start": "electron apps/desktop-live2d/main/electronMain.js",
    "desktop:pack:win": "electron-builder --win nsis --publish never",
    "desktop:dist:win": "electron-builder --win nsis --x64 --publish never",
    "desktop:pack:mac": "electron-builder --mac dmg zip --publish never",
    "desktop:dist:mac": "electron-builder --mac dmg zip --publish never",
    "live2d:import": "node scripts/live2d-import.js",
    "test": "node --test \"test/**/*.test.js\"",
    "test:ci": "node --test $(find test -name '*.test.js' ! -name 'voiceAdapter.test.js')"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "uuid": "^11.0.3",
    "ws": "^8.18.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yachiyo.desktop",
    "productName": "Open Yachiyo",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "apps/**/*",
      "assets/**/*",
      "config/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    }
  }
}
