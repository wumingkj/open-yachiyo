{
  // Window overrides. Delete any field here to fall back to shared defaults.
  "window": {
    "width": 380,
    "height": 600,
    "minWidth": 240,
    "minHeight": 360,
    "compactWidth": 320,
    "compactHeight": 600
  },
  // Interaction overrides. dragZone defines the draggable hotspot as ratios of the avatar window.
  "interaction": {
    "dragZone": {
      "widthRatio": 0.333,
      "heightRatio": 0.333
    }
  },
  "voice": {
    "path": "electron_native",
    "transport": "non_streaming",
    "outputDelayMs": 9,
    "fallbackOnRealtimeError": true,
    "realtime": {
      "prebufferMs": 160,
      "idleTimeoutMs": 8000
    }
  }
}
